{
  "name": "@seungyeop-lee/beads-ui",
  "version": "0.16.0",
  "description": "Local web UI for Beads (bd), the issue tracker for AI coding agents — issues, epics, and kanban board with live updates and inline editing.",
  "keywords": [
    "beads",
    "claude-code",
    "issue-tracker",
    "coding-agent",
    "ai-agents",
    "agentic-coding",
    "kanban-board",
    "local-first",
    "web-ui",
    "developer-tools"
  ],
  "homepage": "https://github.com/seungyeop-lee/beads-ui",
  "author": "seungyeop-lee",
  "type": "module",
  "bin": {
    "bdui": "bin/bdui.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "all": "pnpm lint && pnpm tsc && pnpm test && pnpm prettier:check",
    "start": "node server/index.js --debug",
    "build": "node scripts/build-frontend.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "tsc": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --ext .js .",
    "prettier:write": "prettier --write .",
    "prettier:check": "prettier --check .",
    "preversion": "pnpm all",
    "version": "changes --commits --footer",
    "postversion": "git push --follow-tags && pnpm publish",
    "prepack": "pnpm build",
    "install:global": "pnpm pack && pnpm add -g \"$PWD\"/seungyeop-lee-beads-ui-*.tgz; EXIT=$?; rm -f seungyeop-lee-beads-ui-*.tgz; exit $EXIT",
    "uninstall:global": "pnpm remove -g @seungyeop-lee/beads-ui"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "dependencies": {
    "debug": "^4.4.3",
    "dompurify": "^3.3.0",
    "express": "^5.2.1",
    "lit-html": "^3.3.1",
    "marked": "^17.0.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@studio/changes": "^3.0.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.1",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.1",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsdoc": "^61.4.1",
    "eslint-plugin-n": "^17.9.0",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "lefthook": "^2.1.6",
    "prettier": "^3.7.4",
    "typescript": "^5.6.3",
    "vitest": "^4.0.15"
  },
  "files": [
    "app/index.html",
    "app/favicon.png",
    "app/styles.css",
    "app/main.bundle.js",
    "app/main.bundle.js.map",
    "app/protocol.js",
    "bin",
    "server",
    "CHANGES.md",
    "LICENSE",
    "README.md",
    "!**/*.test.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seungyeop-lee/beads-ui.git"
  }
}
